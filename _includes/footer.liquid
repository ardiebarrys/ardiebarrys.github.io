<style>
  #back-to-top,
  .back-to-top,
  .vanilla-back-to-top,
  button[aria-label="Back to top"],
  button[title="Back to top"],
  a[aria-label="Back to top"],
  a[title="Back to top"],
  div[style*="position: fixed"][style*="bottom"],
  button[style*="position: fixed"][style*="bottom"],
  a[style*="position: fixed"][style*="bottom"] {
    width: 4rem !important;
    height: 4rem !important;
    bottom: 4.7rem !important;
    right: 1.6rem !important;
    z-index: 99999 !important;
    background: #111111 !important;
    color: #ffffff !important;
    border-radius: 999px !important;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.28) !important;
    opacity: 0 !important;
    pointer-events: none !important;
    transform: translateY(0.4rem) !important;
    transition:
      opacity 0.45s ease,
      transform 0.45s ease !important;
  }

  #back-to-top.is-visible,
  .back-to-top.is-visible,
  .vanilla-back-to-top.is-visible,
  button[aria-label="Back to top"].is-visible,
  button[title="Back to top"].is-visible,
  a[aria-label="Back to top"].is-visible,
  a[title="Back to top"].is-visible,
  div[style*="position: fixed"][style*="bottom"].is-visible,
  button[style*="position: fixed"][style*="bottom"].is-visible,
  a[style*="position: fixed"][style*="bottom"].is-visible {
    opacity: 1 !important;
    pointer-events: auto !important;
    transform: translateY(0) !important;
  }

  #back-to-top *,
  .back-to-top *,
  .vanilla-back-to-top * {
    color: #ffffff !important;
    fill: #ffffff !important;
  }

  footer,
  footer.fixed-bottom,
  .fixed-bottom {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
    font-size: 0.85rem !important;
  }

  footer *,
  .fixed-bottom * {
    color: #ffffff !important;
  }

  body {
    padding-bottom: 5rem !important;
  }

  @media (max-width: 768px) {
    #back-to-top,
    .back-to-top,
    .vanilla-back-to-top,
    button[aria-label="Back to top"],
    button[title="Back to top"],
    a[aria-label="Back to top"],
    a[title="Back to top"],
    div[style*="position: fixed"][style*="bottom"],
    button[style*="position: fixed"][style*="bottom"],
    a[style*="position: fixed"][style*="bottom"] {
      width: 3.6rem !important;
      height: 3.6rem !important;
      bottom: 4.7rem !important;
      right: 1rem !important;
    }
  }
</style>

<script>
  (function () {
    var fadeTimer;
    var scrollThreshold = 180;

    var selectors = [
      "#back-to-top",
      ".back-to-top",
      ".vanilla-back-to-top",
      'button[aria-label="Back to top"]',
      'button[title="Back to top"]',
      'a[aria-label="Back to top"]',
      'a[title="Back to top"]',
      'div[style*="position: fixed"][style*="bottom"]',
      'button[style*="position: fixed"][style*="bottom"]',
      'a[style*="position: fixed"][style*="bottom"]'
    ];

    function getButtons() {
      return Array.prototype.slice.call(
        document.querySelectorAll(selectors.join(","))
      );
    }

    function hideButtons() {
      getButtons().forEach(function (button) {
        button.classList.remove("is-visible");
      });
    }

    function showButtons() {
      if (window.scrollY <= scrollThreshold) {
        hideButtons();
        return;
      }

      getButtons().forEach(function (button) {
        button.classList.add("is-visible");
      });

      clearTimeout(fadeTimer);

      fadeTimer = setTimeout(function () {
        hideButtons();
      }, 3000);
    }

    function start() {
      hideButtons();

      window.addEventListener("scroll", showButtons, { passive: true });
      window.addEventListener("mousemove", showButtons, { passive: true });
      window.addEventListener("touchstart", showButtons, { passive: true });
      window.addEventListener("keydown", showButtons);

      var observer = new MutationObserver(function () {
        showButtons();
      });

      observer.observe(document.body, {
        childList: true,
        subtree: true
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", start);
    } else {
      start();
    }
  })();
</script>

<footer class="fixed-bottom">
  <div class="container mt-0">
    &copy; Copyright {{ site.time | date: "%Y" }} Ardie Barry Sailis.
  </div>
</footer>
