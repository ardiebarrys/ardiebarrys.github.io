<style>
  #back-to-top,
  .back-to-top,
  .vanilla-back-to-top,
  button[aria-label="Back to top"],
  button[title="Back to top"],
  a[aria-label="Back to top"],
  a[title="Back to top"],
  div[style*="position: fixed"][style*="bottom"],
  button[style*="position: fixed"][style*="bottom"],
  a[style*="position: fixed"][style*="bottom"] {
    width: 4rem !important;
    height: 4rem !important;
    bottom: 4.7rem !important;
    right: 1.6rem !important;
    z-index: 99999 !important;
    background: #111111 !important;
    color: #ffffff !important;
    border-radius: 999px !important;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.28) !important;
    opacity: 1;
    transition: opacity 0.45s ease !important;
  }

  #back-to-top *,
  .back-to-top *,
  .vanilla-back-to-top * {
    color: #ffffff !important;
    fill: #ffffff !important;
  }

  body {
    padding-bottom: 5rem !important;
  }

  @media (max-width: 768px) {
    #back-to-top,
    .back-to-top,
    .vanilla-back-to-top,
    button[aria-label="Back to top"],
    button[title="Back to top"],
    a[aria-label="Back to top"],
    a[title="Back to top"],
    div[style*="position: fixed"][style*="bottom"],
    button[style*="position: fixed"][style*="bottom"],
    a[style*="position: fixed"][style*="bottom"] {
      width: 3.6rem !important;
      height: 3.6rem !important;
      bottom: 4.9rem !important;
      right: 1rem !important;
    }
  }
</style>

<script>
  (function () {
    let fadeTimer;

    const selectors = [
      "#back-to-top",
      ".back-to-top",
      ".vanilla-back-to-top",
      'button[aria-label="Back to top"]',
      'button[title="Back to top"]',
      'a[aria-label="Back to top"]',
      'a[title="Back to top"]',
      'div[style*="position: fixed"][style*="bottom"]',
      'button[style*="position: fixed"][style*="bottom"]',
      'a[style*="position: fixed"][style*="bottom"]'
    ];

    function getButtons() {
      return Array.from(document.querySelectorAll(selectors.join(",")));
    }

    function showThenFade() {
      getButtons().forEach(function (button) {
        button.style.opacity = "1";
        button.style.transition = "opacity 0.45s ease";
      });

      clearTimeout(fadeTimer);

      fadeTimer = setTimeout(function () {
        getButtons().forEach(function (button) {
          button.style.opacity = "0.18";
        });
      }, 3000);
    }

    function start() {
      showThenFade();

      window.addEventListener("scroll", showThenFade, { passive: true });
      window.addEventListener("mousemove", showThenFade, { passive: true });
      window.addEventListener("touchstart", showThenFade, { passive: true });
      window.addEventListener("keydown", showThenFade);

      const observer = new MutationObserver(showThenFade);

      observer.observe(document.body, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ["style", "class"]
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", start);
    } else {
      start();
    }
  })();
</script>

